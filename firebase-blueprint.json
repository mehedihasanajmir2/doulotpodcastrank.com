{
  "entities": {
    "website_data": {
      "title": "WebsiteData",
      "description": "Dynamic configurations and content of the website",
      "type": "object",
      "properties": {
        "logo": {
          "type": "object",
          "description": "Website logo text segments"
        },
        "hero": {
          "type": "object",
          "description": "Hero section content"
        },
        "about": {
          "type": "object",
          "description": "About section content"
        },
        "stats": {
          "type": "array",
          "description": "List of dynamic statistics metrics"
        },
        "teamMembers": {
          "type": "array",
          "description": "List of executive team members"
        },
        "episodes": {
          "type": "array",
          "description": "Featured podcast episodes"
        },
        "categories": {
          "type": "array",
          "description": "Content categorizations"
        },
        "pricingPlans": {
          "type": "array",
          "description": "Subscription or pricing models"
        },
        "processSteps": {
          "type": "array",
          "description": "Workflow process milestones"
        },
        "testimonials": {
          "type": "array",
          "description": "Feedback and reviews from clients"
        },
        "contactInfo": {
          "type": "object",
          "description": "General contact information details"
        }
      }
    },
    "booking": {
      "title": "Booking",
      "description": "Saved strategy session registrations and orders by clients",
      "type": "object",
      "properties": {
        "token": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "podcastName": { "type": "string" },
        "platform": { "type": "string" },
        "monthlyDownloads": { "type": "string" },
        "selectedPlan": { "type": "string" },
        "message": { "type": "string" },
        "contactType": { "type": "string" },
        "contactValue": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["token", "name", "email"]
    }
  },
  "firestore": {
    "configs/website_data": {
      "schema": "website_data",
      "description": "The dynamic configurations document of the website."
    },
    "bookings/{bookingId}": {
      "schema": "booking",
      "description": "Registrations and strategy sessions submitted by clients."
    }
  }
}
